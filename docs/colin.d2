vars: {
  d2-config: {
    theme-overrides: {
      N7: "transparent"
    }
  }
}

direction: down

backlog: {
  label: Backlog
  shape: hexagon
  style: {
    fill: "#E6F0FF"
    stroke: "#2B6CB0"
  }
}
todo: {
  label: Todo
  style: {
    stroke: "#2F855A"
  }
}
review: {
  label: Review
  shape: hexagon
  style: {
    fill: "#E6F0FF"
    stroke: "#2B6CB0"
  }
}
in_progress: {
  label: In Progress
  style: {
    fill: "#D9F2E3"
    stroke: "#2F855A"
  }
}
refine: {
  label: Refine
  shape: hexagon
  style: {
    fill: "#E6F0FF"
    stroke: "#2B6CB0"
  }
}
merge: {
  label: Merge
  style: {
    fill: "#D9F2E3"
    stroke: "#2F855A"
  }
}
merged: {
  label: Merged
  style: {
    fill: "#D9F2E3"
    stroke: "#2F855A"
  }
}
done: {
  label: Done
  style: {
    stroke: "#2F855A"
  }
}

backlog -> todo: "Ready for work" {
  style: {
    stroke: "#2563EB"
  }
}

todo -> in_progress: "Claim + Start" {
  style: {
    stroke: "#2563EB"
  }
}
todo -> refine: "Spec Missing" {
  style: {
    stroke: "#2563EB"
  }
}

in_progress -> review: "Execution Complete" {
  style: {
    stroke: "#16A34A"
  }
}
in_progress -> refine: "Needs Clarification" {
  style: {
    stroke: "#16A34A"
  }
}

review -> todo: "Human Rework" {
  style: {
    stroke: "#2563EB"
  }
}
review -> merge: "PR Approved" {
  style: {
    stroke: "#2563EB"
  }
}

refine -> todo: "Spec Added" {
  style: {
    stroke: "#2563EB"
  }
}

merge -> merged: "PR Merged" {
  style: {
    stroke: "#DC2626"
  }
}
merged -> done: "Cleanup Complete" {
  style: {
    stroke: "#16A34A"
  }
}
