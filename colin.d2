title: Colin State Flow

direction: right

state_flow: {
  label: "State Flow"

  automation_states: {
    label: "AI / Automation States"
    style: {
      fill: "#E8F7EE"
      stroke: "#2F855A"
    }

    todo: "Todo"
    todo.shape: rectangle
    todo.style: {
      fill: "#D9F2E3"
      stroke: "#2F855A"
    }
    in_progress: "In Progress"
    in_progress.shape: rectangle
    in_progress.style: {
      fill: "#D9F2E3"
      stroke: "#2F855A"
    }
    merge: "Merge"
    merge.shape: rectangle
    merge.style: {
      fill: "#D9F2E3"
      stroke: "#2F855A"
    }
  }

  human_states: {
    label: "Human States"
    style: {
      fill: "#EEF4FF"
      stroke: "#2B6CB0"
    }

    refine: "Refine"
    refine.shape: hexagon
    refine.style: {
      fill: "#E6F0FF"
      stroke: "#2B6CB0"
    }
    review: "Review"
    review.shape: hexagon
    review.style: {
      fill: "#E6F0FF"
      stroke: "#2B6CB0"
    }
  }

  done: "Done"
  done.style: {
    fill: "#EDF2F7"
    stroke: "#4A5568"
  }

  todo -> in_progress: "Claim + Start"
  todo -> refine: "Spec Missing"

  in_progress -> review: "Execution Complete"
  in_progress -> refine: "Needs Clarification"

  review -> merge: "Human Approved"
  review -> todo: "Human Rework"
  refine -> todo: "Spec Added"

  merge -> done: "Merged Successfully"
}

noops_and_gates: {
  label: "Deferred / No-op Conditions"

  blocked: "Issue blocked by dependency\n(blocking issue not in Done)"
  lease_other: "Active lease owned by another worker"
  merge_wait: "Merge state with merge_ready != true"
  merge_queue: "Additional Merge issues in same cycle\n(only first Merge issue processed)"
  merge_fail: "Merge execution failure"

  blocked -> todo: "Blocked Issue"
  blocked -> in_progress: "Blocked Issue"
  blocked -> merge: "Blocked Issue"

  lease_other -> todo: "Other Lease"
  lease_other -> in_progress: "Other Lease"

  merge_wait -> merge: "Await Ready"
  merge_queue -> merge: "Queue Deferred"
  merge_fail -> merge: "Retry Later"
}

notes: {
  label: "Notes"

  n1: "Automated candidate states: Todo, In Progress, Merge"
  n2: "Allowed transitions are constrained in internal/workflow/states.go"
  n3: "Review/Refine transitions are human-driven in current implementation"
  n4: "Flow nodes match legend styles"
}

legend: {
  label: "Legend"

  automation_key: "Automation State"
  automation_key.shape: rectangle
  automation_key.style: {
    fill: "#D9F2E3"
    stroke: "#2F855A"
  }

  human_key: "Human State"
  human_key.shape: hexagon
  human_key.style: {
    fill: "#E6F0FF"
    stroke: "#2B6CB0"
  }

  done_key: "Terminal State"
  done_key.shape: rectangle
  done_key.style: {
    fill: "#EDF2F7"
    stroke: "#4A5568"
  }
}
