# Colin configuration file.
# Environment variables override file values when both are set.
# Backend options:
# - "http": talks to Linear GraphQL API (requires token/team id)
# - "fake": in-memory backend for offline/local testing

linear_api_token = ""
linear_team_id = ""
linear_base_url = "https://api.linear.app/graphql"
linear_backend = "http"
# Root for Colin worktrees and task artifacts.
colin_home = "~/.colin"
# Recommended: set an explicit worker id in shared environments.
worker_id = ""
# Polling and lease durations use Go duration syntax ("30s", "5m", "1h").
poll_every = "30s"
lease_ttl = "5m"
# Number of concurrent issue processors.
max_concurrency = 8
# When true, compute decisions but skip Linear writes.
dry_run = false
